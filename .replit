modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "discord-bot"

[[workflows.workflow]]
name = "discord-bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c \"fuser -k 5000/tcp 2>/dev/null || true; sleep 1; node server.js & node index.js\""

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 34073
externalPort = 3002

[[ports]]
localPort = 34257
externalPort = 5000

[[ports]]
localPort = 40583
externalPort = 3003

[[ports]]
localPort = 44263
externalPort = 3000

[[ports]]
localPort = 45385
externalPort = 4200

[[ports]]
localPort = 45871
externalPort = 3001

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "node server.js & node index.js"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PREFIX = "!"
STRIKE_LIMIT = "3"
TIMEOUT_SECONDS = "600"
